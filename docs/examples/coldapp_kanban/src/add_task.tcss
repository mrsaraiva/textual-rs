AddTaskScreen {
    align: center middle;
    background: $surface;
    border: thick $primary;
    width: 60;
    height: auto;
    padding: 1 2;
}

#add-title {
    text-style: bold;
    color: $accent;
    width: 100%;
    text-align: center;
}

AddTaskScreen Input {
    margin: 1 0;
}

AddTaskScreen Button {
    margin: 0 1 0 0;
}
