[0-15] "I must not fear." fg=#e0e0e0 bg=#800080
[16-59] "                                            " fg=def bg=#800080
[60-119] "                                                            " fg=def bg=#121212
--row 0--
[0-23] "Fear is the mind-killer." fg=#e0e0e0 bg=#800080
[24-59] "                                    " fg=def bg=#800080
[60-119] "                                                            " fg=def bg=#121212
--row 1--
[0-55] "Fear is the little-death that brings total obliteration." fg=#e0e0e0 bg=#800080
[56-59] "    " fg=def bg=#800080
[60-119] "                                                            " fg=def bg=#121212
--row 2--
[0-19] "I will face my fear." fg=#e0e0e0 bg=#800080
[20-59] "                                        " fg=def bg=#800080
[60-119] "                                                            " fg=def bg=#121212
--row 3--
[0-47] "I will permit it to pass over me and through me." fg=#e0e0e0 bg=#800080
[48-59] "            " fg=def bg=#800080
[60-119] "                                                            " fg=def bg=#121212
--row 4--
[0-58] "And when it has gone past, I will turn the inner eye to see" fg=#e0e0e0 bg=#800080
[59-59] " " fg=def bg=#800080
[60-119] "                                                            " fg=def bg=#121212
--row 5--
[0-8] "its path." fg=#e0e0e0 bg=#800080
[9-59] "                                                   " fg=def bg=#800080
[60-119] "                                                            " fg=def bg=#121212
--row 6--
[0-57] "Where the fear has gone there will be nothing. Only I will" fg=#e0e0e0 bg=#800080
[58-59] "  " fg=def bg=#800080
[60-119] "                                                            " fg=def bg=#121212
--row 7--
[0-6] "remain." fg=#e0e0e0 bg=#800080
[7-59] "                                                     " fg=def bg=#800080
[60-119] "                                                            " fg=def bg=#121212
