--row 3--
[0-7] "        " fg=def bg=#ffffff
[8-111] "▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁" fg=#0000ff bg=#ffffff
[112-119] "        " fg=def bg=#ffffff
--row 4--
[0-7] "        " fg=def bg=#ffffff
[8-8] "▎" fg=#0000ff bg=#ccccff
[9-24] "I must not fear." fg=#000000 bg=#ccccff
[25-110] "                                                                                      " fg=def bg=#ccccff
[111-111] "▊" fg=#0000ff bg=#ccccff
[112-119] "        " fg=def bg=#ffffff
--row 5--
[0-7] "        " fg=def bg=#ffffff
[8-8] "▎" fg=#0000ff bg=#ccccff
[9-32] "Fear is the mind-killer." fg=#000000 bg=#ccccff
[33-110] "                                                                              " fg=def bg=#ccccff
[111-111] "▊" fg=#0000ff bg=#ccccff
[112-119] "        " fg=def bg=#ffffff
--row 6--
[0-7] "        " fg=def bg=#ffffff
[8-8] "▎" fg=#0000ff bg=#ccccff
[9-64] "Fear is the little-death that brings total obliteration." fg=#000000 bg=#ccccff
[65-110] "                                              " fg=def bg=#ccccff
[111-111] "▊" fg=#0000ff bg=#ccccff
[112-119] "        " fg=def bg=#ffffff
--row 7--
[0-7] "        " fg=def bg=#ffffff
[8-8] "▎" fg=#0000ff bg=#ccccff
[9-28] "I will face my fear." fg=#000000 bg=#ccccff
[29-110] "                                                                                  " fg=def bg=#ccccff
[111-111] "▊" fg=#0000ff bg=#ccccff
[112-119] "        " fg=def bg=#ffffff
--row 8--
[0-7] "        " fg=def bg=#ffffff
[8-8] "▎" fg=#0000ff bg=#ccccff
[9-56] "I will permit it to pass over me and through me." fg=#000000 bg=#ccccff
[57-110] "                                                      " fg=def bg=#ccccff
[111-111] "▊" fg=#0000ff bg=#ccccff
[112-119] "        " fg=def bg=#ffffff
--row 9--
[0-7] "        " fg=def bg=#ffffff
[8-8] "▎" fg=#0000ff bg=#ccccff
[9-77] "And when it has gone past, I will turn the inner eye to see its path." fg=#000000 bg=#ccccff
[78-110] "                                 " fg=def bg=#ccccff
[111-111] "▊" fg=#0000ff bg=#ccccff
[112-119] "        " fg=def bg=#ffffff
--row 10--
[0-7] "        " fg=def bg=#ffffff
[8-8] "▎" fg=#0000ff bg=#ccccff
[9-74] "Where the fear has gone there will be nothing. Only I will remain." fg=#000000 bg=#ccccff
[75-110] "                                    " fg=def bg=#ccccff
[111-111] "▊" fg=#0000ff bg=#ccccff
[112-119] "        " fg=def bg=#ffffff
