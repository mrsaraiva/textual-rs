[59-59] "┃" fg=#ffff00 bg=#00008b
[60-119] "                                                            " fg=def bg=#121212
--row 7--
[0-0] "┃" fg=#ffff00 bg=#00008b
[1-58] "Where the fear has gone there will be nothing. Only I will" fg=#e0e0e0 bg=#00008b
[59-59] "┃" fg=#ffff00 bg=#00008b
[60-119] "                                                            " fg=def bg=#121212
