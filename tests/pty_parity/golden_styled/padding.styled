--row 2--
[0-119] "                                                                                                                        " fg=def bg=#ccccff
--row 3--
[0-7] "        " fg=def bg=#ccccff
[8-23] "I must not fear." fg=#0000ff bg=#ccccff
[24-119] "                                                                                                " fg=def bg=#ccccff
--row 4--
[0-7] "        " fg=def bg=#ccccff
[8-31] "Fear is the mind-killer." fg=#0000ff bg=#ccccff
[32-119] "                                                                                        " fg=def bg=#ccccff
--row 5--
[0-7] "        " fg=def bg=#ccccff
[8-63] "Fear is the little-death that brings total obliteration." fg=#0000ff bg=#ccccff
[64-119] "                                                        " fg=def bg=#ccccff
--row 6--
[0-7] "        " fg=def bg=#ccccff
[8-27] "I will face my fear." fg=#0000ff bg=#ccccff
[28-119] "                                                                                            " fg=def bg=#ccccff
--row 7--
[0-7] "        " fg=def bg=#ccccff
[8-55] "I will permit it to pass over me and through me." fg=#0000ff bg=#ccccff
[56-119] "                                                                " fg=def bg=#ccccff
--row 8--
[0-7] "        " fg=def bg=#ccccff
[8-76] "And when it has gone past, I will turn the inner eye to see its path." fg=#0000ff bg=#ccccff
[77-119] "                                           " fg=def bg=#ccccff
--row 9--
[0-7] "        " fg=def bg=#ccccff
[8-73] "Where the fear has gone there will be nothing. Only I will remain." fg=#0000ff bg=#ccccff
[74-119] "                                              " fg=def bg=#ccccff
